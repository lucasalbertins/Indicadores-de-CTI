	concept IEP < base:ParceiroChave
	concept SetorPrivado < base:ParceiroChave
	concept ComunidadeCientificaEEcossistemaDeCTI < base:ParceiroChave
	concept Aluno < base:ParceiroChave
	concept Sociedade < base:ParceiroChave
	
	concept Oportunidade < base:FatorExterno
	concept Desafio < base:FatorExterno
	
	concept RecursoFinanceiro < base:Entrada
	concept RecursoHumano < base:Entrada
	concept InfraestruturaETecnologia < base:Entrada
	concept ConhecimentoEArticulacao < base:Entrada
	
	concept FomentoEFinanciamento < base:AtividadeChave
	concept ImplementacaoEGestao < base:AtividadeChave
	concept ArticulacaoEApoio < base:AtividadeChave
	
	concept Saida < base:EntidadeNomeavel
	
	concept Objetivo < base:EntidadeNomeavel, base:EntidadeDescritivel
	
	concept FormacaoEQualificacaoDeRH < base:Resultado
