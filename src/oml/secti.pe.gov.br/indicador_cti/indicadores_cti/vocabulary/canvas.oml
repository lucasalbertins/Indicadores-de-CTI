vocabulary <http://secti.pe.gov.br/indicador_cti/indicadores_cti/vocabulary/canvas#> as canvas {
	
	extends <http://secti.pe.gov.br/indicador_cti/indicadores_cti/vocabulary/base#> as base
	
	concept AgenciaDeFomentoEFinanciamento < base:ParceiroChave
