description <http://secti.pe.gov.br/indicador_cti/indicadores_cti/description/instancias-programas-CTI#> as instancias-programas-CTI {
	
	uses <http://secti.pe.gov.br/indicador_cti/indicadores_cti/vocabulary/base#> as base
	uses <http://secti.pe.gov.br/indicador_cti/indicadores_cti/vocabulary/canvas#> as canvas
	uses <http://secti.pe.gov.br/indicador_cti/indicadores_cti/vocabulary/programa-CTI#> as programa-CTI
	uses <http://www.w3.org/2001/XMLSchema#> as xsd
	
	instance PBPG : programa-CTI:ProgramaCTI [
		base:nome "Programa de Concessão de Bolsas de Pós-Graduação"
		base:descricao "Programa de apoio à pós-graduação stricto sensu em Pernambuco"
		programa-CTI:anoCriacao "2008-05-22T08:00:00Z"^^xsd:dateTime
		programa-CTI:palavrasChave "Inovação, Pesquisa, Empreendedorismo, Formação de Talentos"
	]
	
	instance CAPES : canvas:AgenciaDeFomentoEFinanciamento [
		base:nome "Coordenação de Aperfeiçoamento de Pessoal de Nível Superior - CAPES"
	]
	
	instance CriseOrcamentaria : canvas:Desafio [
		base:nome "Crise Orçamentária"
	]
	
	instance BolsistaMestrado : canvas:RecursoHumano [
		base:nome "Bolsista de Mestrado"
	]
	
	instance LancamentoEdital : canvas:FomentoEFinanciamento [
		base:nome "Lançamento de editais de fomento"
	]
	
	instance RelatorioPesquisa : canvas:Saida [
		base:nome "Relatórios de acompanhamento de teses/dissertações"
	]
	
	instance FormarRH : canvas:Objetivo [
		base:nome "Formação de Recursos Humanos de Alto Nível"
		base:descricao "Formar mestres e doutores para atender às demandas do Estado de Pernambuco"
	]
	
	instance AumentoConceito : canvas:ProducaoCientificaETecnologica [
		base:nome "Melhora em relação ao aumento do conceito CAPES dos programas de pós-graduação"
	]
	
	instance AlunoPos : canvas:BeneficiarioDireto [
		base:nome "Aluno de Pós-Graduação"
	]
	
	relation instance possuiParceiros : programa-CTI:possuiParceiros [
		from PBPG
		to CAPES
	]
	
	relation instance condicionadoPor : programa-CTI:condicionadoPor [
		from PBPG
		to CriseOrcamentaria
	]
	
	relation instance recebeEntradas : programa-CTI:recebeEntradas [
		from PBPG
		to BolsistaMestrado
	]
	
	relation instance executaAtividade : programa-CTI:executaAtividade [
		from PBPG
		to LancamentoEdital
	]
	
	relation instance geraSaidas : programa-CTI:geraSaidas [
		from PBPG
		to RelatorioPesquisa
	]
	
	relation instance buscaAtingir : programa-CTI:buscaAtingir [
		from PBPG
		to FormarRH
	]
	
	relation instance produzResultados : programa-CTI:produzResultados [
		from PBPG
		to AumentoConceito
	]
	
	relation instance direcionadoA : programa-CTI:direcionadoA [
		from PBPG
		to AlunoPos
	]
}